// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`AppShell snapshot > 手機典型（sidebar + main + bottomNav，無 sheet） 1`] = `"<div class="app-shell" data-layout="2pane" data-testid="app-shell"><aside class="app-shell-sidebar" data-testid="app-shell-sidebar"><div class="mock-sidebar">Sidebar</div></aside><main class="app-shell-main" data-testid="app-shell-main"><div class="mock-main">Main</div></main><nav class="app-shell-bottom-nav" data-testid="app-shell-bottom-nav" aria-label="主要功能"><div class="mock-nav">BottomNav</div></nav></div>"`;

exports[`AppShell snapshot > 桌機 2-pane（sidebar + main，無 sheet 無 bottomNav） 1`] = `"<div class="app-shell" data-layout="2pane" data-testid="app-shell"><aside class="app-shell-sidebar" data-testid="app-shell-sidebar"><div class="mock-sidebar">Sidebar</div></aside><main class="app-shell-main" data-testid="app-shell-main"><div class="mock-main">Main</div></main></div>"`;

exports[`AppShell snapshot > 桌機 3-pane（sidebar + main + sheet + bottomNav 全 slot） 1`] = `"<div class="app-shell" data-layout="3pane" data-testid="app-shell"><aside class="app-shell-sidebar" data-testid="app-shell-sidebar"><div class="mock-sidebar">Sidebar</div></aside><main class="app-shell-main" data-testid="app-shell-main"><div class="mock-main">Main</div></main><aside class="app-shell-sheet" data-testid="app-shell-sheet"><div class="mock-sheet">Sheet</div></aside><nav class="app-shell-bottom-nav" data-testid="app-shell-bottom-nav" aria-label="主要功能"><div class="mock-nav">BottomNav</div></nav></div>"`;
