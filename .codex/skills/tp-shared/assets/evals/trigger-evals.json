  "overlap_matrix": {
    "description": "容易混淆的 skill pairs + 判斷依據",
    "pairs": [
      {
        "skills": ["tp-check", "tp-rebuild"],
        "boundary": "tp-check 只讀不改（驗證），tp-rebuild 讀+改（修復）",
        "trigger_words": {
          "tp-check": ["驗證", "檢查", "check", "validate", "report"],
          "tp-rebuild": ["修正", "修復", "重整", "fix", "rebuild", "repair"]
        }
      },
      {
        "skills": ["tp-edit", "tp-request"],
        "boundary": "tp-edit 由 Key User 直接下指令，tp-request 處理旅伴透過 D1 API 送出的請求",
        "trigger_words": {
          "tp-edit": ["改", "換", "加", "刪", "swap", "add", "remove"],
          "tp-request": ["請求", "旅伴", "request", "companion", "處理待處理"]
        }
      },
      {
        "skills": ["tp-edit", "tp-patch"],
        "boundary": "tp-edit 改單一行程的任意內容，tp-patch 跨行程批次補特定欄位",
        "trigger_words": {
          "tp-edit": ["Day N", "某天", "某個景點", "局部"],
          "tp-patch": ["批次", "所有", "跨行程", "bulk", "--target", "--field"]
        }
      },
      {
        "skills": ["tp-team", "tp-code-verify"],
        "boundary": "tp-team 是完整 7 階段 pipeline，tp-code-verify 是 Review 階段的子步驟",
        "trigger_words": {
          "tp-team": ["改 code", "新功能", "bug fix", "重構", "feature"],
          "tp-code-verify": ["commit 前", "tsc", "npm test", "命名規範"]
        }
      },
      {
        "skills": ["tp-check", "tp-daily-check"],
        "boundary": "tp-check 手動驗證特定行程，tp-daily-check 排程自動掃描全部 + Telegram 通知",
        "trigger_words": {
          "tp-check": ["驗證", "這個行程", "指定 tripId"],
          "tp-daily-check": ["每日", "排程", "daily", "Telegram", "健康檢查"]
        }
      }
    ]
