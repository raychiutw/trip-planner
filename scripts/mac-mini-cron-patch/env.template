# CF_ACCESS_CLIENT_ID=...
# CF_ACCESS_CLIENT_SECRET=...

# Added (v2.22.0)：
TRIPLINE_API_CLIENT_ID=tripline-internal-cli
# TRIPLINE_API_CLIENT_SECRET=<貼這裡，56 chars，從 .env.local 複製>

