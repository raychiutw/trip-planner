{
  "ci": {
    "collect": {
      "url": [
        "https://trip-planner-dby.pages.dev/",
        "https://trip-planner-dby.pages.dev/trip/okinawa-trip-2026-Ray",
        "https://trip-planner-dby.pages.dev/trip/okinawa-trip-2026-Ray/stop/419",
        "https://trip-planner-dby.pages.dev/explore",
        "https://trip-planner-dby.pages.dev/login"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "onlyCategories": ["performance", "accessibility"]
      }
    },
    "assert": {
      "assertions": {
        "largest-contentful-paint": ["error", {"maxNumericValue": 3000}],
        "total-blocking-time": ["error", {"maxNumericValue": 400}],
        "cumulative-layout-shift": ["error", {"maxNumericValue": 0.15}],
        "categories:performance": ["error", {"minScore": 0.7}],
        "categories:accessibility": ["error", {"minScore": 0.9}]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
