{
  "name": "tripline",
  "version": "2.55.75",
  "private": true,
  "scripts": {
    "dev": "concurrently -n vite,api -c cyan,green \"vite\" \"wrangler pages dev dist --local --port 8788 --d1 DB\"",
    "dev:vite": "vite",
    "dev:staging": "concurrently -n vite,api -c cyan,yellow \"vite\" \"wrangler pages dev dist --local --port 8788 --d1 DB -b ENVIRONMENT=preview\"",
    "dev:prod": "concurrently -n vite,api -c cyan,red \"vite\" \"wrangler pages dev dist --port 8788\"",
    "dev:init": "node scripts/init-local-db.js",
    "dev:reset": "node scripts/init-local-db.js --reset",
    "build": "cross-env BROWSERSLIST=\"last 2 Chrome versions\" vite build && node -e \"const fs=require('fs');const p=require('path');['admin','manage'].forEach(d=>{fs.mkdirSync(p.join('dist',d),{recursive:true});fs.copyFileSync(p.join('dist','index.html'),p.join('dist',d,'index.html'))})\"",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:functions": "tsc --noEmit -p tsconfig.functions.json",
    "test": "vitest run",
    "test:api": "vitest run --config vitest.config.api.mts",
    "test:all": "vitest run && vitest run --config vitest.config.api.mts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify-sw": "node scripts/verify-sw.js",
    "memory:export": "bash scripts/memory-sync.sh export",
    "memory:import": "bash scripts/memory-sync.sh import",
    "_runtime_note": "Google scripts use bun (TypeScript native, no node loader needed). Others node.",
    "backfill:google": "bun scripts/google-poi-initial-backfill.ts",
    "refresh:google": "bun scripts/google-poi-refresh-30d.ts",
    "quota:google": "bun scripts/google-quota-monitor.ts",
    "lint": "eslint \"src/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260628.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/runner": "^4.1.9",
    "@vitest/snapshot": "^4.1.9",
    "axe-core": "^4.12.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^16.6.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "jsdom": "^26.0.0",
    "miniflare": "^4.20260625.0",
    "serve": "^14.2.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  },
  "_overrides_note": "v2.33.61 round 14: pin transitive deps to patch HIGH CVE per `npm audit` 2026-05-24. Re-audit + remove if upstream releases fix.",
  "overrides": {
    "@babel/plugin-transform-modules-systemjs": "^7.29.4",
    "serialize-javascript": "^7.0.5",
    "fast-uri": "^3.1.2",
    "dompurify": "^3.4.10"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@googlemaps/js-api-loader": "^2.1.1",
    "@headlessui/react": "^2.2.10",
    "@sentry/react": "^10.65.0",
    "@sentry/vite-plugin": "^5.4.0",
    "@types/google.maps": "^3.64.0",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-react": "^6.0.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "html2pdf.js": "^0.14.0",
    "idb": "^8.0.3",
    "marked": "^17.0.4",
    "nodemailer": "^9.0.1",
    "oidc-provider": "^9.8.4",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  }
}
