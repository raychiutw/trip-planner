{
  "name": "tripline",
  "version": "2.14.12",
  "private": true,
  "scripts": {
    "dev": "concurrently -n vite,api -c cyan,green \"vite\" \"wrangler pages dev dist --local --port 8788\"",
    "dev:vite": "vite",
    "dev:staging": "concurrently -n vite,api -c cyan,yellow \"vite\" \"wrangler pages dev dist --env preview --port 8788\"",
    "dev:prod": "concurrently -n vite,api -c cyan,red \"vite\" \"wrangler pages dev dist --port 8788\"",
    "dev:init": "node scripts/init-local-db.js",
    "dev:reset": "node scripts/init-local-db.js --reset",
    "build": "cross-env BROWSERSLIST=\"last 2 Chrome versions\" vite build && node -e \"const fs=require('fs');const p=require('path');['admin','manage'].forEach(d=>{fs.mkdirSync(p.join('dist',d),{recursive:true});fs.copyFileSync(p.join('dist','index.html'),p.join('dist',d,'index.html'))})\"",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:functions": "tsc --noEmit -p tsconfig.functions.json",
    "test": "vitest run",
    "test:api": "vitest run --config vitest.config.api.mts",
    "test:all": "vitest run && vitest run --config vitest.config.api.mts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify-sw": "node scripts/verify-sw.js",
    "memory:export": "bash scripts/memory-sync.sh export",
    "memory:import": "bash scripts/memory-sync.sh import"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260329.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supercluster": "^7.1.3",
    "@vitest/runner": "^4.1.0",
    "@vitest/snapshot": "^4.1.0",
    "axe-core": "^4.11.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^26.0.0",
    "miniflare": "^4.20260317.3",
    "serve": "^14.2.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.80.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@sentry/react": "^10.45.0",
    "@sentry/vite-plugin": "^5.1.1",
    "@vitejs/plugin-react": "^6.0.1",
    "clsx": "^2.1.1",
    "html2pdf.js": "^0.14.0",
    "idb": "^8.0.3",
    "leaflet": "^1.9.4",
    "marked": "^17.0.4",
    "oidc-provider": "^9.8.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "supercluster": "^8.0.1"
  }
}
